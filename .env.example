# Copy to .env and fill before Sepolia broadcast / deploy
# CRE_ACCOUNT_EMAIL=
# CRE_API_KEY=

# Required for deploy + broadcast simulation
# CRE_ETH_PRIVATE_KEY=0x...

# Optional RPC override
# SEPOLIA_RPC_URL=

# Optional Oracle Court deployment defaults
# ORACLE_COURT_THROTTLE_MINT_LIMIT=1000
# ORACLE_COURT_INITIAL_RESERVE_COVERAGE_BPS=10000
# ORACLE_COURT_INITIAL_ATTESTATION_AGE_SECONDS=300
# ORACLE_COURT_INITIAL_REDEMPTION_QUEUE_BPS=200

# Optional runtime telemetry override (set-oracle-court-rwa-telemetry script)
# ORACLE_COURT_RESERVE_COVERAGE_BPS=10000
# ORACLE_COURT_ATTESTATION_AGE_SECONDS=300
# ORACLE_COURT_REDEMPTION_QUEUE_BPS=200
