{
  "name": "chainlink-convergence-hackathon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript CRE starter for Chainlink Convergence Hackathon",
  "scripts": {
    "setup": "bun x cre-setup",
    "typecheck": "tsc --noEmit",
    "simulate": "cre workflow simulate ./src/workflows/hello-world",
    "compile": "bun x cre-compile src/workflows/hello-world/index.ts dist/hello-world.wasm"
  },
  "dependencies": {
    "@chainlink/cre-sdk": "^1.1.2",
    "zod": "^3.25.76",
    "viem": "^2.34.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "typescript": "^5.9.2"
  },
  "engines": {
    "bun": ">=1.2.21"
  }
}
